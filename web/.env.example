# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gctopsales"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/gctopsales"

# --- Auth ---
AUTH_SECRET="generate-with: npx auth secret"
# Super-admin bootstrap account (created by prisma/seed.ts)
ADMIN_EMAIL="admin@gctopsales.local"
ADMIN_PASSWORD="change-me"

# --- AI ---
ANTHROPIC_API_KEY=""
# LLM_PROVIDER=openai + OPENAI_API_KEY to switch providers
GC_LLM_MODEL="claude-sonnet-5"

# --- Voice-note transcription (WhatsApp/IG/Messenger voice messages) ---
# Claude has no audio input, so voice notes use a Whisper service. Preferred:
# Groq (fast + cheap, whisper-large-v3-turbo). Without any key, voice notes
# gracefully hand off to a human.
GROQ_API_KEY=""
# GC_TRANSCRIBE_MODEL="whisper-large-v3-turbo"  # or whisper-large-v3 / whisper-1 (OpenAI)
# Fallback provider if GROQ_API_KEY is unset:
TRANSCRIBE_API_KEY=""
OPENAI_API_KEY=""

# --- Meta webhooks (one app-level verify token shared by all tenants;
#     per-tenant access tokens live in the ChannelConnection table) ---
META_WEBHOOK_VERIFY_TOKEN=""
META_APP_SECRET=""
# Graph API version for outbound sends + media fetch (optional; default v21.0)
META_API_VERSION="v21.0"
# Public https origin — required only for Messenger/Instagram attachment sends
# (they're delivered to Meta by URL, pointing back at /api/attachments/[id]).
PUBLIC_BASE_URL=""

# --- One-click Meta connect (Embedded Signup + Facebook Login for Business) ---
# All three come from developers.facebook.com under the ONE platform Meta app
# (not per-agent). Leave blank and the Connect page falls back to manual
# token paste — nothing breaks. See DEPLOYMENT.md for the full setup
# checklist (Business Verification + App Review are required before this
# works for agents who aren't admins/testers on the Meta app).
# Public — safe to expose client-side (this is how Meta app ids always work).
NEXT_PUBLIC_META_APP_ID=""
# App Dashboard → WhatsApp → Embedded Signup → your configuration's id.
NEXT_PUBLIC_META_WA_CONFIG_ID=""
# App Dashboard → Facebook Login for Business → Configurations → your configuration's id.
NEXT_PUBLIC_META_LOGIN_CONFIG_ID=""

# --- Follow-up scheduler (protects /api/cron/follow-ups) ---
# On Vercel, set this and the cron in vercel.json sends it automatically.
CRON_SECRET=""
